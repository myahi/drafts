<?xml version="1.0" encoding="UTF-8"?>
<pd:ProcessDefinition xmlns:pfx6="http://www.labanquepostale.fr/dmf/FtpRequest/result" xmlns:pfx7="http://regis_tr_xml_load" xmlns:pfx="http://www.lbp.fr/xml" xmlns:pfx2="http://www.tibco.com/ns/no_namespace_schema_location/Resources/Xsd/EAIftpMessage.xsd" xmlns:ns="http://www.tibco.com/pe/DeployedVarsType" xmlns:pfx3="http://www.labanquepostale.fr/xml" xmlns:pfx4="http://www.labanquepostale.fr/xml/gateway/output" xmlns:pfx5="http://www.labanquepostale.fr/dmf/FtpRequest" xmlns:xsd="http://www.w3.org/2001/XMLSchema" xmlns:ns0="www.tibco.com/plugin/Sleep" xmlns:tib="http://www.tibco.com/bw/xslt/custom-functions" xmlns:ns2="http://www.tibco.com/namespaces/tnt/plugins/file" xmlns:ns1="http://www.tibco.com/namespaces/tnt/plugins/jms" xmlns:ns4="http://www.tibco.com/pe/EngineTypes" xmlns:ns3="http://www.tibco.com/pe/GenerateErrorActivity/InputSchema" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsl="http://www.w3.org/1999/XSL/Transform" xmlns:ns6="http://www.calypso.com/xml" xmlns:ns5="http://www.tibco.com/schemas/EAIFramework/framework/resources/XSD/auditInfo.xsd" xmlns:ns8="http://www.labanquepostale.fr/xml/audit/v2" xmlns:wsdl="http://schemas.xmlsoap.org/wsdl/" xmlns:ns7="http://www.labanquepostale.fr/dmf/FtpRequest/request" xmlns:ns9="http://www.tibco.com/namespaces/tnt/plugins/file/v2" xmlns:BW="java://com.tibco.pe.core.JavaCustomXPATHFunctions" xmlns:ns10="http://tibco.com/namespaces/tnt/plugins/soap" xmlns:pd="http://xmlns.tibco.com/bw/process/2003" xmlns:lbp="java://LbpCustomClass">
    <xsd:import namespace="http://www.lbp.fr/xml" schemaLocation="/Resources/Xsd/lbp-bofi-message.xsd"/>
    <xsd:import namespace="http://www.tibco.com/ns/no_namespace_schema_location/Resources/Xsd/EAIftpMessage.xsd" schemaLocation="/Resources/Xsd/EAIftpMessage.xsd"/>
    <xsd:import namespace="http://www.labanquepostale.fr/xml/gateway/output" schemaLocation="/Resources/Xsd/GatewayOutput.xsd"/>
    <xsd:import namespace="http://www.lbp.fr/xml" schemaLocation="/Resources/Xsd/lbp-bofi-routing.xsd"/>
    <xsd:import namespace="http://www.labanquepostale.fr/dmf/FtpRequest/request" schemaLocation="/Resources/Wsdl/EAI_FTP_REQUESTS.wsdl"/>
    <wsdl:import namespace="http://www.labanquepostale.fr/dmf/FtpRequest" location="/Resources/WSDL/EAI_FTP_REQUESTS.wsdl"/>
    <pd:name>Process/Gateways/FTP Gateway Exchanges.process</pd:name>
    <pd:startName>Start</pd:startName>
    <pd:startType>
        <xsd:element name="parameters">
            <xsd:complexType>
                <xsd:sequence>
                    <xsd:element name="fileLocation" type="xsd:string" minOccurs="0"/>
                    <xsd:element name="fileName" type="xsd:string" minOccurs="0"/>
                    <xsd:element name="connectionName" type="xsd:string" minOccurs="0"/>
                    <xsd:element name="remoteLocation" type="xsd:string" minOccurs="0"/>
                    <xsd:element name="format" type="xsd:string" minOccurs="0"/>
                </xsd:sequence>
            </xsd:complexType>
        </xsd:element>
    </pd:startType>
    <pd:startX>27</pd:startX>
    <pd:startY>39</pd:startY>
    <pd:returnBindings>
        <output>
            <pfx4:numberOfFiles>
                <xsl:value-of select="1"/>
            </pfx4:numberOfFiles>
            <pfx4:dollarUNotification>
                <xsl:value-of select="true()"/>
            </pfx4:dollarUNotification>
            <pfx4:isError>
                <xsl:value-of select="false()"/>
            </pfx4:isError>
        </output>
    </pd:returnBindings>
    <pd:endName>End</pd:endName>
    <pd:endX>1163</pd:endX>
    <pd:endY>39</pd:endY>
    <pd:errorSchemas/>
    <pd:processVariables>
        <DBGInfo>
            <xsd:element name="root">
                <xsd:complexType>
                    <xsd:sequence>
                        <xsd:element name="isDBG" type="xsd:boolean"/>
                    </xsd:sequence>
                </xsd:complexType>
            </xsd:element>
        </DBGInfo>
    </pd:processVariables>
    <pd:targetNamespace>http://xmlns.example.com/1269005907093</pd:targetNamespace>
    <pd:activity name="Archive File If Available">
        <pd:type>com.tibco.pe.core.CallProcessActivity</pd:type>
        <pd:resourceType>ae.process.subprocess</pd:resourceType>
        <pd:x>1004</pd:x>
        <pd:y>47</pd:y>
        <config>
            <processName>/framework/process/FileHandling/Rename File If Available.process</processName>
        </config>
        <pd:inputBindings>
            <parameters>
                <sourceName>
                    <xsl:value-of select="concat($Start/parameters/fileLocation,'/',$Start/parameters/fileName)"/>
                </sourceName>
                <targetName>
                    <xsl:value-of select="concat($Start/parameters/fileLocation, $_globalVariables/ns:GlobalVariables/Framework/File/Separator,&#xA;'archives',$_globalVariables/ns:GlobalVariables/Framework/File/Separator, $Start/parameters/fileName)"/>
                </targetName>
            </parameters>
        </pd:inputBindings>
    </pd:activity>
    <pd:activity name="FTP Request (WS)">
        <pd:type>com.tibco.plugin.soap.SOAPSendReceiveActivity</pd:type>
        <pd:resourceType>ae.activities.SOAPSendReceiveUI</pd:resourceType>
        <pd:x>573</pd:x>
        <pd:y>39</pd:y>
        <config>
            <timeout>0</timeout>
            <soapAttachmentStyle>SwA</soapAttachmentStyle>
            <service>pfx5:FtpService</service>
            <servicePort>OperationsEndpoint1</servicePort>
            <operation>SEND_FILE</operation>
            <soapAction>/Process/SourceToEAI/WebService/FtpService.serviceagent/OperationsEndpoint1/SEND_FILE</soapAction>
            <endpointURL>%%EAIparams/FTP/UrlWsEaiFtpExchange%%</endpointURL>
            <timeoutType>Seconds</timeoutType>
            <authScheme>NONE</authScheme>
        </config>
        <pd:inputBindings>
            <inputMessage>
                <ftpRequest>
                    <xsl:copy-of select="$Map-Data/request/ns7:EAIftpMessage"/>
                </ftpRequest>
                <ns10:_configData>
                    <endpointURL>
                        <xsl:value-of select="$_globalVariables/ns:GlobalVariables/EAIparams/FTP/UrlWsEaiFtpExchange"/>
                    </endpointURL>
                </ns10:_configData>
            </inputMessage>
        </pd:inputBindings>
    </pd:activity>
    <pd:activity name="Generate Error SFTP">
        <pd:type>com.tibco.pe.core.GenerateErrorActivity</pd:type>
        <pd:resourceType>ae.activities.throw</pd:resourceType>
        <pd:x>577</pd:x>
        <pd:y>221</pd:y>
        <config>
            <faultName/>
        </config>
        <pd:inputBindings>
            <ns3:ActivityInput>
                <xsl:if test="$FTP-Request-WS/outputMessage/ftpResponse/pfx6:errorMessage">
                    <message>
                        <xsl:value-of select="$FTP-Request-WS/outputMessage/ftpResponse/pfx6:errorMessage"/>
                    </message>
                </xsl:if>
                <xsl:if test="$FTP-Request-WS/outputMessage/ftpResponse/pfx6:errorCode">
                    <messageCode>
                        <xsl:value-of select="$FTP-Request-WS/outputMessage/ftpResponse/pfx6:errorCode"/>
                    </messageCode>
                </xsl:if>
            </ns3:ActivityInput>
        </pd:inputBindings>
    </pd:activity>
    <pd:activity name="Map Data">
        <pd:type>com.tibco.plugin.mapper.MapperActivity</pd:type>
        <pd:resourceType>ae.activities.MapperActivity</pd:resourceType>
        <pd:x>259</pd:x>
        <pd:y>39</pd:y>
        <config>
            <element>
                <xsd:element name="request" type="ns7:FtpMessage"/>
            </element>
        </config>
        <pd:inputBindings>
            <request>
                <ns7:EAIftpMessage>
                    <ns7:Header>
                        <xsl:attribute name="Action">
                            <xsl:value-of select="'send'"/>
                        </xsl:attribute>
                        <xsl:attribute name="ConnectionName">
                            <xsl:value-of select="$Start/parameters/connectionName"/>
                        </xsl:attribute>
                        <xsl:if test="$Start/parameters/remoteLocation">
                            <xsl:attribute name="requestURI">
                                <xsl:value-of select="$Start/parameters/remoteLocation"/>
                            </xsl:attribute>
                        </xsl:if>
                        <ns7:nbMaxRetry>
                            <xsl:value-of select="5"/>
                        </ns7:nbMaxRetry>
                        <ns7:waitForRetry>
                            <xsl:value-of select="30"/>
                        </ns7:waitForRetry>
                        <ns7:batchSchedulerInfo>
                            <xsl:value-of select="false()"/>
                        </ns7:batchSchedulerInfo>
                    </ns7:Header>
                    <ns7:File>
                        <xsl:attribute name="Location">
                            <xsl:value-of select="$Start/parameters/fileLocation"/>
                        </xsl:attribute>
                        <xsl:attribute name="Name">
                            <xsl:value-of select="$Start/parameters/fileName"/>
                        </xsl:attribute>
                        <xsl:if test="$Start/parameters/remoteLocation">
                            <xsl:attribute name="RemoteLocation">
                                <xsl:value-of select="$Start/parameters/remoteLocation"/>
                            </xsl:attribute>
                        </xsl:if>
                        <ns7:Content>
                            <xsl:value-of select="$Read-File/ns2:ReadActivityOutputBinaryClass/fileContent/binaryContent"/>
                        </ns7:Content>
                    </ns7:File>
                </ns7:EAIftpMessage>
            </request>
        </pd:inputBindings>
    </pd:activity>
    <pd:activity name="Read File">
        <pd:type>com.tibco.plugin.file.FileReadActivity</pd:type>
        <pd:resourceType>ae.activities.FileReadActivity</pd:resourceType>
        <pd:x>127</pd:x>
        <pd:y>39</pd:y>
        <config>
            <encoding>binary</encoding>
        </config>
        <pd:inputBindings>
            <ns2:ReadActivityInputClass>
                <fileName>
                    <xsl:value-of select="concat($Start/parameters/fileLocation ,&quot;/&quot;,$Start/parameters/fileName)"/>
                </fileName>
            </ns2:ReadActivityInputClass>
        </pd:inputBindings>
    </pd:activity>
    <pd:activity name="sendAuditInfo">
        <pd:type>com.tibco.pe.core.CallProcessActivity</pd:type>
        <pd:resourceType>ae.process.subprocess</pd:resourceType>
        <pd:x>739</pd:x>
        <pd:y>42</pd:y>
        <config>
            <processName>/framework/process/audit/sendAuditInfoWithCatchException.process</processName>
        </config>
        <pd:inputBindings>
            <audit>
                <ns5:auditInfo>
                    <ns5:timestamp>
                        <xsl:value-of select="current-dateTime()"/>
                    </ns5:timestamp>
                    <ns5:reference>
                        <ns5:code>
                            <xsl:value-of select="$Start/parameters/fileName"/>
                        </ns5:code>
                        <ns5:codifier>
                            <xsl:value-of select="$_globalVariables/ns:GlobalVariables/Framework/Audit/Codifiers/FILE_NAME"/>
                        </ns5:codifier>
                    </ns5:reference>
                    <ns5:metadatas>
                        <ns5:metadata>
                            <ns5:key>
                                <xsl:value-of select="$_globalVariables/ns:GlobalVariables/Framework/Audit/Codifiers/FILE_NAME"/>
                            </ns5:key>
                            <ns5:value>
                                <xsl:value-of select="$Start/parameters/fileName"/>
                            </ns5:value>
                        </ns5:metadata>
                        <ns5:metadata>
                            <ns5:key>
                                <xsl:value-of select="$_globalVariables/ns:GlobalVariables/Framework/Metadatas/FLOW_TYPE"/>
                            </ns5:key>
                            <ns5:value>
                                <xsl:value-of select="$Start/parameters/connectionName"/>
                            </ns5:value>
                        </ns5:metadata>
                        <ns5:metadata>
                            <ns5:key>
                                <xsl:value-of select="'PROCESS_NAME'"/>
                            </ns5:key>
                            <ns5:value>
                                <xsl:value-of select="BW:getCurrentProcessName($_processContext/ns4:ProcessContext/ProcessId)"/>
                            </ns5:value>
                        </ns5:metadata>
                    </ns5:metadatas>
                    <ns5:description>
                        <xsl:value-of select="concat(&quot;Fichier envoyé vers FTP (Format :  &quot;, $Start/parameters/format, &quot;).&quot;)"/>
                    </ns5:description>
                    <ns5:data>
                        <xsl:value-of select="tib:render-xml($FTP-Request-WS/outputMessage/ftpResponse)"/>
                    </ns5:data>
                    <ns5:statut>
                        <xsl:value-of select="$_globalVariables/ns:GlobalVariables/Framework/Status/Success"/>
                    </ns5:statut>
                </ns5:auditInfo>
                <xsl:for-each select="$_processContext/ns4:ProcessContext">
                    <ns4:ProcessContext>
                        <ProcessId>
                            <xsl:value-of select="ProcessId"/>
                        </ProcessId>
                        <ProjectName>
                            <xsl:value-of select="ProjectName"/>
                        </ProjectName>
                        <EngineName>
                            <xsl:value-of select="EngineName"/>
                        </EngineName>
                        <RestartedFromCheckpoint>
                            <xsl:value-of select="RestartedFromCheckpoint"/>
                        </RestartedFromCheckpoint>
                        <xsl:for-each select="TrackingInfo">
                            <TrackingInfo>
                                <xsl:value-of select="."/>
                            </TrackingInfo>
                        </xsl:for-each>
                        <xsl:if test="CustomId">
                            <CustomId>
                                <xsl:value-of select="CustomId"/>
                            </CustomId>
                        </xsl:if>
                    </ns4:ProcessContext>
                </xsl:for-each>
            </audit>
        </pd:inputBindings>
    </pd:activity>
    <pd:activity name="TraceEnd">
        <pd:type>com.tibco.pe.core.CallProcessActivity</pd:type>
        <pd:resourceType>ae.process.subprocess</pd:resourceType>
        <pd:x>857</pd:x>
        <pd:y>39</pd:y>
        <config>
            <processName>/framework/process/logHandling/Trace.process</processName>
        </config>
        <pd:inputBindings>
            <trace>
                <code>
                    <xsl:value-of select="'Report-FTP-002'"/>
                </code>
                <processContext>
                    <ProcessId>
                        <xsl:value-of select="$_processContext/ns4:ProcessContext/ProcessId"/>
                    </ProcessId>
                    <ProjectName>
                        <xsl:value-of select="$_processContext/ns4:ProcessContext/ProjectName"/>
                    </ProjectName>
                    <EngineName>
                        <xsl:value-of select="$_processContext/ns4:ProcessContext/EngineName"/>
                    </EngineName>
                    <RestartedFromCheckpoint>
                        <xsl:value-of select="$_processContext/ns4:ProcessContext/RestartedFromCheckpoint"/>
                    </RestartedFromCheckpoint>
                    <xsl:for-each xmlns:xsl="http://www.w3.org/1999/XSL/Transform" select="$_processContext/ns4:ProcessContext/TrackingInfo">
                        <TrackingInfo>
                            <xsl:value-of select="."/>
                        </TrackingInfo>
                    </xsl:for-each>
                    <xsl:if test="$_processContext/ns4:ProcessContext/CustomId">
                        <CustomId>
                            <xsl:value-of select="$_processContext/ns4:ProcessContext/CustomId"/>
                        </CustomId>
                    </xsl:if>
                </processContext>
                <data>
                    <xsl:copy-of select="$FTP-Request-WS/outputMessage"/>
                </data>
            </trace>
        </pd:inputBindings>
    </pd:activity>
    <pd:activity name="TraceStart">
        <pd:type>com.tibco.pe.core.CallProcessActivity</pd:type>
        <pd:resourceType>ae.process.subprocess</pd:resourceType>
        <pd:x>409</pd:x>
        <pd:y>39</pd:y>
        <config>
            <processName>/framework/process/logHandling/Trace.process</processName>
        </config>
        <pd:inputBindings>
            <trace>
                <code>
                    <xsl:value-of select="'Report-FTP-001'"/>
                </code>
                <processContext>
                    <ProcessId>
                        <xsl:value-of select="$_processContext/ns4:ProcessContext/ProcessId"/>
                    </ProcessId>
                    <ProjectName>
                        <xsl:value-of select="$_processContext/ns4:ProcessContext/ProjectName"/>
                    </ProjectName>
                    <EngineName>
                        <xsl:value-of select="$_processContext/ns4:ProcessContext/EngineName"/>
                    </EngineName>
                    <RestartedFromCheckpoint>
                        <xsl:value-of select="$_processContext/ns4:ProcessContext/RestartedFromCheckpoint"/>
                    </RestartedFromCheckpoint>
                    <xsl:for-each select="$_processContext/ns4:ProcessContext/TrackingInfo">
                        <TrackingInfo>
                            <xsl:value-of select="."/>
                        </TrackingInfo>
                    </xsl:for-each>
                    <xsl:if test="$_processContext/ns4:ProcessContext/CustomId">
                        <CustomId>
                            <xsl:value-of select="$_processContext/ns4:ProcessContext/CustomId"/>
                        </CustomId>
                    </xsl:if>
                </processContext>
                <data>
                    <xsl:copy-of select="$Map-Data/request/ns7:EAIftpMessage"/>
                </data>
            </trace>
        </pd:inputBindings>
    </pd:activity>
    <pd:transition>
        <pd:from>FTP Request (WS)</pd:from>
        <pd:to>sendAuditInfo</pd:to>
        <pd:lineType>Default</pd:lineType>
        <pd:lineColor>-16777216</pd:lineColor>
        <pd:conditionType>otherwise</pd:conditionType>
    </pd:transition>
    <pd:transition>
        <pd:from>FTP Request (WS)</pd:from>
        <pd:to>Generate Error SFTP</pd:to>
        <pd:xpathDescription>Error</pd:xpathDescription>
        <pd:lineType>Default</pd:lineType>
        <pd:lineColor>-16777216</pd:lineColor>
        <pd:conditionType>xpath</pd:conditionType>
        <pd:xpath>$FTP-Request-WS/outputMessage/ftpResponse/pfx6:status='KO'</pd:xpath>
    </pd:transition>
    <pd:transition>
        <pd:from>TraceStart</pd:from>
        <pd:to>FTP Request (WS)</pd:to>
        <pd:lineType>Default</pd:lineType>
        <pd:lineColor>-16777216</pd:lineColor>
        <pd:conditionType>always</pd:conditionType>
    </pd:transition>
    <pd:transition>
        <pd:from>Map Data</pd:from>
        <pd:to>TraceStart</pd:to>
        <pd:lineType>Default</pd:lineType>
        <pd:lineColor>-16777216</pd:lineColor>
        <pd:conditionType>always</pd:conditionType>
    </pd:transition>
    <pd:transition>
        <pd:from>Archive File If Available</pd:from>
        <pd:to>End</pd:to>
        <pd:lineType>Default</pd:lineType>
        <pd:lineColor>-16777216</pd:lineColor>
        <pd:conditionType>always</pd:conditionType>
    </pd:transition>
    <pd:transition>
        <pd:from>sendAuditInfo</pd:from>
        <pd:to>TraceEnd</pd:to>
        <pd:lineType>Default</pd:lineType>
        <pd:lineColor>-16777216</pd:lineColor>
        <pd:conditionType>always</pd:conditionType>
    </pd:transition>
    <pd:transition>
        <pd:from>Start</pd:from>
        <pd:to>Read File</pd:to>
        <pd:lineType>Default</pd:lineType>
        <pd:lineColor>-16777216</pd:lineColor>
        <pd:conditionType>always</pd:conditionType>
    </pd:transition>
    <pd:transition>
        <pd:from>Read File</pd:from>
        <pd:to>Map Data</pd:to>
        <pd:lineType>Default</pd:lineType>
        <pd:lineColor>-16777216</pd:lineColor>
        <pd:conditionType>always</pd:conditionType>
    </pd:transition>
    <pd:transition>
        <pd:from>TraceEnd</pd:from>
        <pd:to>Archive File If Available</pd:to>
        <pd:lineType>Default</pd:lineType>
        <pd:lineColor>-16777216</pd:lineColor>
        <pd:conditionType>always</pd:conditionType>
    </pd:transition>
</pd:ProcessDefinition>
