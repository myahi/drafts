<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://www.m...aven.apache.org/xsd/maven-4.0.0.xsd">

    <modelVersion>4.0.0</modelVersion>

    <!-- Parent -->
    <parent>
        <groupId>fr.labanquepostale.marches.eai</groupId>
        <artifactId>eai-camel-report</artifactId>
        <version>1.0.0-SNAPSHOT</version>
    </parent>

    <artifactId>eai-camel-report-base</artifactId>
    <version>1.0.0-SNAPSHOT</version>
    <packaging>jar</packaging>

    <name>eai-camel-report-base</name>

    <!-- ========================================================= -->
    <!-- Dépendances -->
    <!-- ========================================================= -->
    <dependencies>

        <!-- ======================= -->
        <!-- Camel Core Spring Boot -->
        <!-- ======================= -->
        <dependency>
            <groupId>org.apache.camel.springboot</groupId>
            <artifactId>camel-spring-boot-starter</artifactId>
        </dependency>

        <!-- ======================= -->
        <!-- SOAP (CXF via Camel) -->
        <!-- ======================= -->
        <dependency>
            <groupId>org.apache.camel.springboot</groupId>
            <artifactId>camel-cxf-soap-starter</artifactId>
        </dependency>

        <!-- ======================= -->
        <!-- Composants Camel -->
        <!-- ======================= -->
        <dependency>
            <groupId>org.apache.camel</groupId>
            <artifactId>camel-bindy</artifactId>
        </dependency>

        <dependency>
            <groupId>org.apache.camel</groupId>
            <artifactId>camel-xml-jaxp</artifactId>
        </dependency>

        <!-- ======================= -->
        <!-- Core métier -->
        <!-- ======================= -->
        <dependency>
            <groupId>fr.labanquepostale.marches.eai</groupId>
            <artifactId>eai-camel-core</artifactId>
        </dependency>

        <!-- ======================= -->
        <!-- Monitoring / Metrics -->
        <!-- ======================= -->
        <dependency>
            <groupId>io.micrometer</groupId>
            <artifactId>micrometer-registry-prometheus</artifactId>
        </dependency>

        <dependency>
            <groupId>org.apache.camel.springboot</groupId>
            <artifactId>camel-micrometer-starter</artifactId>
        </dependency>

        <!-- ======================= -->
        <!-- (OPTIONNEL DEV ONLY) -->
        <!-- ======================= -->
        <!--
        <dependency>
            <groupId>org.apache.camel.springboot</groupId>
            <artifactId>camel-console-starter</artifactId>
        </dependency>
        -->

    </dependencies>

    <!-- ========================================================= -->
    <!-- Build -->
    <!-- ========================================================= -->
    <build>
        <finalName>eai-camel-report-base</finalName>

        <plugins>
            <plugin>
                <groupId>org.springframework.boot</groupId>
                <artifactId>spring-boot-maven-plugin</artifactId>
            </plugin>
        </plugins>
    </build>

</project>
